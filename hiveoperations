Step 3: Cmd

Run as administrator
cd C:\hive\bin
hive
hive>

Program Execution
Create Database
hive> CREATE DATABASE IF NOT EXISTS database_usn;
hive> USE database_usn;
Create Table
CREATE TABLE IF NOT EXISTS student (
    id INT,
    name STRING,
    age INT,
    department STRING,
    salary FLOAT
)
ROW FORMAT DELIMITED
FIELDS TERMINATED BY ','
STORED AS TEXTFILE;

Insert Data
hive> INSERT INTO TABLE student VALUES
(1, 'John Doe', 20, 'Engineering', 5000.0),
(2, 'Jane Smith', 22, 'Marketing', 5500.0),
(3, 'Michael Johnson', 21, 'Sales', 6000.0),
(4, 'Emily Davis', 23, 'HR', 6500.0),
(5, 'James Brown', 24, 'Finance', 7000.0);

Read Data
SELECT * FROM student;
Delete One Row (e.g., id = 2)

Since Hive doesn't support direct row deletion, overwrite the table:

INSERT OVERWRITE TABLE student
SELECT * FROM student WHERE id != 2;
Read to Verify
SELECT * FROM student;
Update a Record (e.g., Update Salary for id = 3)

Hive does not support direct UPDATE, so use overwrite:

INSERT OVERWRITE TABLE student
SELECT
    CASE WHEN id = 3 THEN id ELSE id END AS id,
    CASE WHEN id = 3 THEN 'Michael Johnson' ELSE name END AS name,
    CASE WHEN id = 3 THEN 21 ELSE age END AS age,
    CASE WHEN id = 3 THEN 'Sales' ELSE department END AS department,
    CASE WHEN id = 3 THEN 6500.0 ELSE salary END AS salary

FROM student;
Drop Table
DROP TABLE IF EXISTS student;
Drop Database
DROP DATABASE IF EXISTS database_usn CASCADE;
